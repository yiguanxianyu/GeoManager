{
  "name": "data-sharing-platform-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "api:lint": "redocly lint ../docs/openapi.yaml --config ./redocly.yaml",
    "api:bundle": "mkdir -p generated && redocly bundle ../docs/openapi.yaml --config ./redocly.yaml -o generated/openapi-bundled.yaml --ext yaml",
    "api:docs": "mkdir -p generated && redocly build-docs ../docs/openapi.yaml --config ./redocly.yaml -o generated/api-reference.html --disableGoogleFont",
    "generate:api": "pnpm run api:lint && openapi-ts",
    "check:api": "pnpm run api:lint && rm -rf generated/api-check && openapi-ts -o generated/api-check --silent && diff -qr src/api/generated generated/api-check && rm -rf generated/api-check",
    "api:changes:check": "node scripts/check-api-change-requests.mjs",
    "mock:build": "mkdir -p ../mock/prism && redocly bundle ../docs/openapi.yaml --config ./redocly.yaml -o ../mock/prism/openapi.prism.json --ext json && node scripts/inject-prism-examples.mjs",
    "mock:api": "pnpm run mock:build && prism mock ../mock/prism/openapi.prism.json --host 127.0.0.1 --port 4010",
    "dev:mock": "vite --host 127.0.0.1 --mode mock",
    "dev:with-mock": "concurrently -k -n prism,vite -c cyan,green \"pnpm run mock:api\" \"pnpm run dev:mock\"",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "build": "vite build",
    "build:verify": "pnpm run check:api && pnpm run typecheck && vite build",
    "perf:mock": "node scripts/perf-mock.mjs",
    "perf:compare": "node scripts/perf-compare.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest --config vitest.config.ts run",
    "test:browser": "vitest --config vitest.browser.config.ts run --browser.headless",
    "test:browser:watch": "vitest --config vitest.browser.config.ts --browser.headless=false",
    "check": "oxlint . --no-error-on-unmatched-pattern && oxfmt . --check --no-error-on-unmatched-pattern",
    "fix": "oxlint . --fix --no-error-on-unmatched-pattern && oxfmt . --write --no-error-on-unmatched-pattern",
    "version:patch": "pnpm version patch",
    "version:minor": "pnpm version minor",
    "version:major": "pnpm version major"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@ant-design/pro-components": "3.1.12-0",
    "antd": "^6.4.4",
    "dayjs": "^1.11.21",
    "mapbox-gl": "^3.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@ant-design/cli": "^6.4.4",
    "@hey-api/openapi-ts": "0.98.2",
    "@redocly/cli": "^2.34.0",
    "@stoplight/prism-cli": "^5.15.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.9",
    "concurrently": "^10.0.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "playwright": "^1.61.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0"
  },
  "packageManager": "pnpm@11.8.0"
}
