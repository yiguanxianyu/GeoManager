{
  "name": "data-sharing-platform-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "api:lint": "redocly lint ../docs/openapi.yaml --config ./redocly.yaml",
    "api:bundle": "redocly bundle ../docs/openapi.yaml --config ./redocly.yaml -o ../docs/openapi-bundled.yaml --ext yaml",
    "api:docs": "redocly build-docs ../docs/openapi.yaml --config ./redocly.yaml -o ../docs/api-reference.html --disableGoogleFont",
    "generate:api": "pnpm run api:lint && openapi-typescript ../docs/openapi.yaml --empty-objects-unknown --array-length --default-non-nullable false -o src/api/schema.d.ts",
    "check:api": "pnpm run api:lint && openapi-typescript ../docs/openapi.yaml --empty-objects-unknown --array-length --default-non-nullable false -o src/api/schema.d.ts --check",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "build": "vite build",
    "build:verify": "pnpm run check:api && pnpm run typecheck && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "format": "biome format . --write",
    "lint": "biome lint .",
    "check": "biome check .",
    "fix": "biome check . --write",
    "version:patch": "pnpm version patch",
    "version:minor": "pnpm version minor",
    "version:major": "pnpm version major",
    "version:prerelease": "pnpm version prerelease"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@ant-design/pro-components": "^3.1.12-0",
    "antd": "^6.4.3",
    "dayjs": "^1.11.20",
    "mapbox-gl": "^3.24.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@redocly/cli": "^2.31.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "happy-dom": "^20.10.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.0"
}
