# Docker Compose 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# TOML 配置文件路径（宿主机上的绝对路径）
APP_CONFIG_FILE=./config/app.docker.toml

# 数据目录（宿主机上的路径）
APP_DATA_HOST=./data/business
GEOGRAPHIC_DATA_HOST=./data/geographic

# HTTP 端口（默认 80）
APP_HTTP_PORT=80

# Mapbox Access Token（公共 token，以 pk. 开头）
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Django Allowed Hosts（逗号分隔，默认 * 即接受所有，由 nginx 把关）
# 如需限制可取消注释：
# DJANGO_ALLOWED_HOSTS=192.236.148.86,localhost,127.0.0.1

# Django Secret Key（生产环境请设置一个随机值）
# DJANGO_SECRET_KEY=your-secret-key-here

# Gunicorn worker 数量
GUNICORN_WORKERS=1

# Nginx 上游地址（默认 django:8000）
# DJANGO_UPSTREAM=django:8000

# Nginx 最大上传大小（默认 512m）
# CLIENT_MAX_BODY_SIZE=512m
